# GLM-4.7 API Key
ZHIPUAI_API_KEY=your_api_key_here

# GLM-4.7 Model ID
ZHIPUAI_MODEL=glm-4.7

# API Endpoint (可选，默认使用官方endpoint)
# ZHIPUAI_API_BASE=https://open.bigmodel.cn/api/paas/v4/

# Log Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 最大重试次数
MAX_RETRIES=3

# 请求超时时间 (秒)
REQUEST_TIMEOUT=120

# Stream响应块大小
STREAM_CHUNK_SIZE=4
